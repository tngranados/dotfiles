#!/usr/bin/env ruby

require 'tmpdir'

def main(args)
  paths, out, width = parse_args(args)
  gif = File.extname(out).downcase == '.gif'

  Dir.mktmpdir('sschanges') do |dir|
    prepared_paths = paths.each_with_index.map do |path, index|
      prepare_image(path, width, dir, index)
    end

    if gif
      make_gif(prepared_paths, out)
    else
      join(prepared_paths, out)
    end
  end
end

def parse_args(args)
  paths = args.dup
  width = 350
  resize_index = paths.index('--resize')

  if resize_index
    width = Integer(paths.fetch(resize_index + 1))
    raise ArgumentError, usage if width <= 0

    paths.slice!(resize_index, 2)
  end

  out = paths.pop
  raise ArgumentError, usage if out.nil? || paths.empty?

  [paths, out, width]
rescue IndexError, ArgumentError
  raise ArgumentError, usage
end

def command_available?(name)
  ENV.fetch('PATH', '').split(File::PATH_SEPARATOR).any? do |dir|
    executable = File.join(dir, name)
    File.executable?(executable) && !File.directory?(executable)
  end
end

def convert_command
  command_available?('magick') ? ['magick'] : ['convert']
end

def montage_command
  command_available?('montage') ? ['montage'] : ['magick', 'montage']
end

def annotation_font
  [
    '/System/Library/Fonts/Menlo.ttc',
    '/System/Library/Fonts/Supplemental/Arial.ttf',
    '/System/Library/Fonts/Helvetica.ttc'
  ].find { |path| File.exist?(path) }
end

def prepare_image(path, width, dir, index)
  out = File.join(dir, format('%02d-%s', index, File.basename(path)))
  label = File.basename(path, File.extname(path))
  command = [
    *convert_command,
    path,
    '-resize', width.to_s,
    '-gravity', 'North',
    '-pointsize', '70',
    '-fill', 'red'
  ]

  font = annotation_font
  command += ['-font', font] if font
  command += ['-annotate', '-0+40', label, out]

  system(*command, exception: true)

  out
end

def join(paths, out)
  command = [
    *montage_command,
    *paths
  ]

  font = annotation_font
  command += ['-font', font] if font
  command += [
    '-tile', "#{paths.length}x1",
    '-geometry', '+10+10',
    '-background', 'none',
    out
  ]

  system(*command, exception: true)
end

def make_gif(paths, out)
  system(*convert_command, '-delay', '100', '-loop', '0', *paths, out, exception: true)
end

def usage
  <<~USAGE
    Usage:
    sschanges pic1.png [pic2.png ...] out.png # Join screenshots side by side annotated with their file names
    sschanges pic1.png [pic2.png ...] out.gif # Create a gif from screenshots annotated with their file names
    sschanges pic1.png [pic2.png ...] out.png --resize 500 # Resize each image to 500px wide
  USAGE
end

begin
  main(ARGV)
rescue ArgumentError => e
  warn e.message
  exit 1
end
